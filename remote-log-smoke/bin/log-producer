#!/bin/sh
set -eu

service="${1:-app}"
interval="${HEARTBEAT_INTERVAL_SECONDS:-5}"
counter=0

echo "{\"event\":\"startup\",\"service\":\"${service}\",\"message\":\"producer started\"}"

while true; do
  counter=$((counter + 1))
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"event":"heartbeat","service":"%s","sequence":%s,"timestamp":"%s"}\n' \
    "$service" "$counter" "$ts"
  sleep "$interval"
done
